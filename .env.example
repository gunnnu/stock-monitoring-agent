# Copy to .env for local testing (never commit real secrets).
# In GitHub, add these as repository secrets instead (Settings → Secrets and variables → Actions).

# ---- Email (SMTP) ----
# Example for Gmail: use an App Password (not your normal password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=recipient1@example.com,recipient2@example.com

# ---- Telegram ----
# Create a bot via @BotFather to get the token.
# Get your chat id via @userinfobot or the getUpdates API.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789
